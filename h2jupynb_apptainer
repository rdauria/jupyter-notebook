def _send_ctrl_break(p):
  """Try to interrupt a child process group on Windows using
  GenerateConsoleCtrlEvent; otherwise send SIGINT or kill.
  """
  try:
    if opsys == 'Windows':
      try:
        ctypes.windll.kernel32.GenerateConsoleCtrlEvent(1, int(p.pid))
        time.sleep(0.2)
      except Exception:
        try:
          p.kill()
        except Exception:
          pass
  except Exception:
    pass

