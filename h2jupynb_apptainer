def gethostname(line):
    """
    Check a line from the remote output and extract the hostname.
    Returns True if hostname was found, False otherwise.
    """
    global hostname
    line = line.strip()
    if line.startswith('HOSTNAME'):
        hostname = line.partition('=')[2].strip()
        return True
    return False

